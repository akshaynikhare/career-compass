# Copy to backend/.env for local development. NEVER commit the real .env.
# In production, set these in the FastAPI Cloud dashboard instead.

# Neon pooled connection string (Neon dashboard -> Connection Details -> Pooled)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Google Gemini API key (server-side only)
GEMINI_KEY=your_gemini_api_key

# Random secret guarding GET /api/results (generate with: openssl rand -hex 24)
ADMIN_TOKEN=change_me_to_a_long_random_string

# CORS: comma-separated origins allowed to call the API
ALLOWED_ORIGINS=https://akshaynikhare.github.io

# Optional overrides
GEMINI_MODEL=gemini-2.0-flash
AI_RATE_LIMIT=20/minute
